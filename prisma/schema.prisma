generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum AccessLevel {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum MemberStatus {
  INVITED
  PENDING
  ACTIVE
  DISABLED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  phone        String?
  createdAt    DateTime @default(now())

  memberships BusinessMember[]
}

model Business {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  members   BusinessMember[]
  locations Location[]
  jobRoles  JobRole[]
  invites   Invite[]
}

model Location {
  id         Int    @id @default(autoincrement())
  businessId Int
  name       String
  address    String?

  business Business @relation(fields: [businessId], references: [id])

  memberLocations MemberLocation[]

  @@unique([businessId, name])
}

model JobRole {
  id         Int      @id @default(autoincrement())
  businessId Int
  name       String
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  memberJobRoles MemberJobRole[]

  @@unique([businessId, name])
}

model BusinessMember {
  id          Int          @id @default(autoincrement())
  userId      Int?
  businessId  Int
  staffId     String
  fullName    String
  email       String
  phone       String?
  accessLevel AccessLevel  @default(EMPLOYEE)
  status      MemberStatus @default(INVITED)
  createdAt   DateTime     @default(now())

  user     User?    @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  jobRoles         MemberJobRole[]
  locations        MemberLocation[]
  employeesManaged EmployeeManager[] @relation("ManagerToEmployees")
  managers         EmployeeManager[] @relation("EmployeeToManagers")

  @@unique([businessId, staffId])
  @@unique([businessId, email])
}

model MemberJobRole {
  id       Int @id @default(autoincrement())
  memberId Int
  roleId   Int

  member BusinessMember @relation(fields: [memberId], references: [id])
  role   JobRole        @relation(fields: [roleId], references: [id])

  @@unique([memberId, roleId])
}

model MemberLocation {
  id         Int @id @default(autoincrement())
  memberId   Int
  locationId Int

  member   BusinessMember @relation(fields: [memberId], references: [id])
  location Location       @relation(fields: [locationId], references: [id])

  @@unique([memberId, locationId])
}

model EmployeeManager {
  id         Int @id @default(autoincrement())
  employeeId Int
  managerId  Int

  employee BusinessMember @relation("EmployeeToManagers", fields: [employeeId], references: [id])
  manager  BusinessMember @relation("ManagerToEmployees", fields: [managerId], references: [id])

  @@unique([employeeId, managerId])
}

model Invite {
  id          Int          @id @default(autoincrement())
  businessId  Int
  memberId    Int?
  staffId     String
  fullName    String
  email       String
  phone       String?
  inviteCode  String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, staffId])
  @@unique([businessId, email])
}